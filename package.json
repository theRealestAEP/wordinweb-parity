{
  "name": "wordinweb-parity",
  "private": true,
  "version": "0.1.0",
  "description": "Demo, browser tests, and visual-parity corpus for wordinweb",
  "license": "PolyForm-Noncommercial-1.0.0",
  "workspaces": [
    "wordinweb/packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w @docxinweb/core -w @docxinweb/react && npm run build -w demo",
    "test": "npm run test -w @docxinweb/core",
    "test:integration": "vitest run tests/incr-equiv.test.ts",
    "dev": "npm run dev -w demo",
    "test:e2e": "playwright test",
    "parity": "node scripts/parity-compare.mjs",
    "report:snapshot": "cp parity/out/report.html apps/demo/public/report.html"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
